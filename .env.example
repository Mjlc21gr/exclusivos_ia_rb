# =============================================================================
# RVE Microservice - Variables de Entorno
# =============================================================================
# Copiar a .env y rellenar los valores reales.
# NUNCA subir .env al repositorio.

# -----------------------------------------------------------------------------
# Google Sheets
# -----------------------------------------------------------------------------
SPREADSHEET_ID=your_spreadsheet_id_here
SHEET_TURNOS=TURNOS_TECNICOS
SHEET_SERVICIOS=SERVICIOS
SHEET_PREASIGNACIONES=PREASIGNACIONES
SHEET_CONFIG=CONFIG
SHEET_DATOS_TECNICOS=DATOS_TECNICOS

# Ruta al JSON de service account para Google Sheets
# En Cloud Run se usa ADC (Application Default Credentials) y no es necesario
SERVICE_ACCOUNT_FILE=service-account.json

# -----------------------------------------------------------------------------
# API Security
# -----------------------------------------------------------------------------
# API Key requerida en header X-Api-Key para endpoints /rve/*
ENDPOINT_API_KEY=

# -----------------------------------------------------------------------------
# Motor de Decision: ortools | gemini | legacy
# -----------------------------------------------------------------------------
DECISION_ENGINE=ortools

# -----------------------------------------------------------------------------
# Gemini 2.5 Flash (solo si DECISION_ENGINE=gemini)
# -----------------------------------------------------------------------------
GEMINI_SERVICE_ACCOUNT_FILE=gemini-service-account.json
GEMINI_REGION=us-central1
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SECONDS=15

# -----------------------------------------------------------------------------
# Google Maps Distance Matrix (distancias reales con trafico)
# -----------------------------------------------------------------------------
# Si no se configura, usa haversine como fallback
GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# Configuracion Operativa
# -----------------------------------------------------------------------------
AVERAGE_SPEED_KMH=22
BUFFER_SERVICIO_MINUTOS=5
ONSITE_MINUTES=12
RADIO_MAX_KM=25
PRE_SHIFT_TRAVEL_MINUTES=40
HORIZON_DAYS=8
MIN_NOTICE_MINUTES=60
SERVICE_TIMEOUT_SECONDS=120

# -----------------------------------------------------------------------------
# OR-Tools (solo si DECISION_ENGINE=ortools)
# -----------------------------------------------------------------------------
ORTOOLS_TIME_LIMIT_SECONDS=8
ORTOOLS_LOCAL_SEARCH_SECONDS=7
ORTOOLS_MOVE_PENALTY_KM=2.0
ORTOOLS_FIRST_SOLUTION_STRATEGY=PARALLEL_CHEAPEST_INSERTION
ORTOOLS_LOCAL_SEARCH_METAHEURISTIC=GUIDED_LOCAL_SEARCH

# -----------------------------------------------------------------------------
# Google Sheets - Timeouts y Reintentos
# -----------------------------------------------------------------------------
SHEETS_HTTP_TIMEOUT_SECONDS=12
SHEETS_MAX_RETRIES=2
SHEET_CACHE_TTL_SECONDS=300
LOCK_TIMEOUT_SECONDS=150
LOCK_RETRY_SECONDS=5
LOCK_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# Notificaciones (Google Chat Webhook)
# -----------------------------------------------------------------------------
# URL completa del webhook de Google Chat para alertas de rechazo
GOOGLE_CHAT_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Test Clock (solo para desarrollo local)
# -----------------------------------------------------------------------------
ALLOW_TEST_CLOCK=false

# -----------------------------------------------------------------------------
# Datadog Observability
# -----------------------------------------------------------------------------
DATADOG_ENABLED=false
DD_SITE=datadoghq.com
DD_SERVICE=rve-microservice
DD_ENV=dev
DD_VERSION=latest
DD_API_KEY=
